$ Comprehensive Pebble test
say "Hello Pebble!"

x is 2 ^ 3
say x
$ Output: 8

nums is {1, 2, 3}
count is 0
go n in nums:
    count is count + 1
say count
$ Output: 3

fnc greet(name):
    say "Hello " + name

greet("Rasa")

nums is {0, 1, 2}
go i in nums:
    say "Hello"

x is 10
if x big 5:
    say "x is bigger than 5"

numbers is {10, 20, 30}
say numbers

person is [name: "Rasa", age: 14]
say person

go n in numbers:
    say n * 2

say person["name"]
say person["age"]

$ Demonstrate WAWE (Why Add When Else exists)
score is 75
if score big 90:
    say "Grade A"
if score big 80 and score sml 90:
    say "Grade B"
if score big 70 and score sml 80:
    say "Grade C"
if score sml 70:
    say "Grade D"

$ Demonstrate ! (logical NOT)
if !true:
    say "This will NOT print"
if !false:
    say "This will print"

name is inp["Enter your name: "]
say "Hello " + name